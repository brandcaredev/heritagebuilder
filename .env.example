# Since the ".env" file is gitignored, you can use this file to create a local ".env"
# when you clone the repo. Keep it up-to-date when you add new variables to `.env`.
#
# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.
#
# Local Supabase:
# - `supabase start`
# - `supabase status -o env` (to verify keys/urls)

NODE_ENV="development"

# Payload
PAYLOAD_SECRET="local-payload-secret-change-me"

# Database (Supabase local Postgres)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:8832/postgres"

# Supabase (local)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:8831"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

S3_BUCKET="supabase-payload"
S3_ACCESS_KEY_ID="625729a08b95bf1b7ff351a663f3a23c"
S3_SECRET_ACCESS_KEY="850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907"
S3_REGION="local"
S3_ENDPOINT="http://127.0.0.1:8831/storage/v1/s3"

# Email (required by env validation; local dev won't actually send)
RESEND_API_KEY="re_local_dummy"
BASE_EMAIL="noreply@localhost"

# AI (Payload admin content generation)
AI_ENABLED=false
AI_RATE_LIMIT_PER_MIN=10
AI_TIMEOUT_MS=25000
OPENROUTER_AI_KEY=
